{
  "name": "kxyy-desktop-pet",
  "version": "0.2.22",
  "description": "元元桌宠 · 基于 webmeji 动画的 macOS / Windows 跨平台桌面宠物（Tauri）",
  "author": "aaronfang",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test tests/realtime-trace.test.js tests/realtime-audio-worklets.test.js",
    "test:python": "node scripts/run-python-tests.mjs",
    "tauri": "tauri",
    "dev": "tauri dev",
    "predev": "node scripts/kill-services.mjs && npm run encrypt-assets",
    "build": "npm run encrypt-assets && node scripts/bundle-assets.mjs strip && tauri build && node scripts/bundle-assets.mjs restore",
    "build:win": "npm run build -- --bundles nsis",
    "build:mac": "npm run build -- --bundles dmg",
    "sync-assets": "node scripts/sync-assets.mjs",
    "sync-ai": "node scripts/sync-ai.mjs",
    "encrypt-assets": "node scripts/build-persona-enc.mjs",
    "distill": "cd scripts/persona-distill && python pipeline.py",
    "validate-card": "python scripts/persona-distill/tools/validate_card.py",
    "update-persona": "npm run validate-card -- persona-cards/kxyy-yuanyuan/persona-card.json && npm run encrypt-assets"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2"
  }
}
