{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "元元桌宠",
  "version": "0.2.22",
  "identifier": "com.aaronfang.kxyydesktoppet",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "width": 800,
        "height": 600,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "skipTaskbar": true,
        "shadow": false,
        "focus": false,
        "visible": false
      },
      {
        "label": "chat",
        "url": "chat.html",
        "width": 420,
        "height": 340,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "skipTaskbar": true,
        "shadow": false,
        "focus": true,
        "visible": false
      },
      {
        "label": "settings",
        "title": "元元桌宠 · 设置",
        "url": "settings.html",
        "width": 680,
        "height": 780,
        "resizable": true,
        "maximizable": false,
        "skipTaskbar": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../scripts/local-realtime/common.py": "scripts/local-realtime/common.py",
      "../scripts/local-realtime/server.py": "scripts/local-realtime/server.py",
      "../scripts/local-realtime/server_cosyvoice.py": "scripts/local-realtime/server_cosyvoice.py",
      "../scripts/local-realtime/tts_cosyvoice.py": "scripts/local-realtime/tts_cosyvoice.py",
      "../scripts/local-realtime/tts_qwen3_torch.py": "scripts/local-realtime/tts_qwen3_torch.py",
      "../scripts/local-realtime/requirements-macos.txt": "scripts/local-realtime/requirements-macos.txt",
      "../scripts/local-realtime/requirements-windows.txt": "scripts/local-realtime/requirements-windows.txt",
      "../scripts/macos/setup-qwen3-tts.sh": "scripts/macos/setup-qwen3-tts.sh",
      "../scripts/windows/setup-qwen3-tts.cmd": "scripts/windows/setup-qwen3-tts.cmd",
      "../scripts/windows/setup-qwen3-tts.ps1": "scripts/windows/setup-qwen3-tts.ps1",
      "../scripts/local-realtime/assets/kxyy-yuanyuan": "scripts/local-realtime/assets/kxyy-yuanyuan",
      "../scripts/local-realtime/assets/bazi-persona": "scripts/local-realtime/assets/bazi-persona",
      "../scripts/local-realtime/assets/elon-musk": "scripts/local-realtime/assets/elon-musk",
      "../persona-cards": "persona-cards"
    },
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": false
      }
    }
  }
}
