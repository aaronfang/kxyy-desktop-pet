{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "元元桌宠",
  "version": "0.2.2",
  "identifier": "com.aaronfang.kxyydesktoppet",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "width": 800,
        "height": 600,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "skipTaskbar": true,
        "shadow": false,
        "focus": false,
        "visible": false
      },
      {
        "label": "chat",
        "url": "chat.html",
        "width": 420,
        "height": 340,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "skipTaskbar": true,
        "shadow": false,
        "focus": true,
        "visible": false
      },
      {
        "label": "settings",
        "title": "元元桌宠 · 设置",
        "url": "settings.html",
        "width": 600,
        "height": 760,
        "resizable": true,
        "maximizable": false,
        "skipTaskbar": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
